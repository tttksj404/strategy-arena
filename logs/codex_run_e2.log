import { Pressable, ScrollView, StyleSheet, Text, View } from 'react-native';
import { Ionicons } from '@expo/vector-icons';

import { LensCard } from '../components/LensCard';
import { StatusPill } from '../components/StatusPill';
import { StoreSafeNotice } from '../components/StoreSafeNotice';
import { isMonetizationEnabled, purchasePro, restorePurchases } from '../services/monetization';
import { palette, radius, space, typography } from '../theme/tokens';
import type { ThemeMode } from '../theme/tokens';
import type { RaceDecision } from '../types/race';

type ProScreenProps = {
  mode: ThemeMode;
  decision: RaceDecision;
  freeAnalysisLimit: number;
  freeAnalysisUsed: number;
};

const freeFeatures = [
  '기본 예측 순서와 후보 신뢰도',
  '선수·말 기본 정보와 배당 자료',
  '무료 분석 한도 적용',
  '고급 복기와 검증 로그는 잠금'
];

const proFeatures = [
  '광고 제거 및 무제한 조회',
  '고확신 필터와 마감 직전 갱신',
  '과거 유사 경주와 복기 리포트',
  '모델 후보의 검증 로그'
];

const lockedFeatures = [
  '고확신 후보만 모아보기',
  '마감 직전 배당 변화 알림',
  '유사 경주 비교 리포트',
  '모델 검증 로그 전체 열람'
];

const proExperience = [
  ['분석 횟수', '무제한'],
  ['광고', '표시 안 함'],
  ['고급 신호', '필터·배당·유사 경주 열림'],
  ['복기 로그', '전체 열람']
];

export function ProScreen({ mode, decision, freeAnalysisLimit, freeAnalysisUsed }: ProScreenProps) {
  const colors = palette(mode);
  const proActive = decision.appSession.entitlement === 'pro';
  const monetizationEnabled = isMonetizationEnabled();
  const safeUsed = Math.min(freeAnalysisLimit, freeAnalysisUsed);
  const freeRemaining = Math.max(0, freeAnalysisLimit - safeUsed);
  const freeExperience = [
    ['분석 횟수', `오늘 ${safeUsed}/${freeAnalysisLimit} 사용`],
    ['남은 횟수', `${freeRemaining}회`],
    ['광고', monetizationEnabled ? '분석 중간 광고 슬롯 표시' : '심사 전 비활성'],
    ['고급 신호', '값은 가리고 잠금 카드 노출']
  ];
  return (
    <ScrollView contentContainerStyle={styles.content} showsVerticalScrollIndicator={false}>
      <View style={styles.header}>
        <StatusPill mode={mode} level={proActive ? 'verified' : 'neutral'} label={proActive ? 'PRO ACTIVE' : 'FREE PLAN'} />
        <Text style={[styles.title, { color: colors.textPrimary }]}>RaceLens Pro</Text>
        <Text style={[styles.subtitle, { color: colors.textSecondary }]}>
          Pro 차이는 분석 화면에서 바로 체감되도록 광고, 조회 한도, 고급 신호 잠금을 실제 상태로 나눕니다.
        </Text>
      </View>

      <LensCard mode={mode} variant={proActive ? 'pro' : 'caution'}>
        <View style={styles.planHeader}>
          <Text style={[styles.sectionTitle, { color: colors.textPrimary }]}>현재 적용 상태</Text>
          <StatusPill mode={mode} level={proActive ? 'pro' : 'neutral'} label={proActive ? 'Pro 경험' : '무료 경험'} />
        </View>
        <View style={styles.experienceGrid}>
          {(proActive ? proExperience : freeExperience).map(([label, value]) => (
            <View key={label} style={[styles.experienceCell, { borderColor: colors.borderSubtle, backgroundColor: colors.surfaceInset }]}>
              <Text style={[styles.experienceLabel, { color: colors.textMuted }]}>{label}</Text>
              <Text style={[styles.experienceValue, { color: colors.textPrimary }]}>{value}</Text>
            </View>
          ))}
        </View>
      </LensCard>

      <View style={styles.planGrid}>
        <LensCard mode={mode} variant={proActive ? 'neutral' : 'verified'}>
          <View style={styles.planHeader}>
            <Text style={[styles.planName, { color: colors.textPrimary }]}>무료 플랜</Text>
            {!proActive ? <StatusPill mode={mode} level="verified" label="현재 이용 중" /> : null}
          </View>
          <Text style={[styles.price, { color: colors.textSecondary }]}>0원</Text>
          <Text style={[styles.caption, { color: colors.textSecondary }]}>기본 분석과 광고 기반 이용</Text>
          <View style={styles.benefits}>
            {freeFeatures.map((feature) => (
              <FeatureRow key={feature} mode={mode} label={feature} locked={feature.includes('잠금')} />
            ))}
          </View>
        </LensCard>

        <LensCard mode={mode} variant="pro">
          <View style={styles.planHeader}>
            <Text style={[styles.planName, { color: colors.textPrimary }]}>Pro 플랜</Text>
            {proActive ? <StatusPill mode={mode} level="pro" label="활성" /> : <StatusPill mode={mode} level="pro" label="월 구독" />}
          </View>
          <Text style={[styles.price, { color: colors.textSecondary }]}>월 5,000원</Text>
          <Text style={[styles.caption, { color: colors.textSecondary }]}>광고 제거와 고급 분석 잠금 해제</Text>
          <View style={styles.benefits}>
            {proFeatures.map((feature) => (
              <FeatureRow key={feature} mode={mode} label={feature} locked={false} />
            ))}
          </View>
          <View style={styles.ctaGroup}>
            <Pressable
              accessibilityRole="button"
              accessibilityState={{ disabled: !monetizationEnabled || proActive }}
              onPress={() => {
                if (monetizationEnabled && !proActive) void purchasePro();
              }}
              style={({ pressed }) => [
                styles.ctaButton,
                {
                  backgroundColor: monetizationEnabled && !proActive ? colors.accentPrimary : colors.surfaceInset,
                  borderColor: monetizationEnabled && !proActive ? colors.accentPrimary : colors.borderSubtle,
                  opacity: pressed ? 0.88 : 1
                }
              ]}
            >
              <Text style={[styles.ctaText, { color: monetizationEnabled && !proActive ? colors.textOnBoard : colors.textMuted }]}>
                {proActive ? 'Pro 이용 중' : monetizationEnabled ? 'Pro 구독 시작' : '스토어 심사 준비 중'}
              </Text>
            </Pressable>
            <Pressable
              accessibilityRole="button"
              accessibilityState={{ disabled: !monetizationEnabled }}
              onPress={() => {
                if (monetizationEnabled) void restorePurchases();
              }}
              style={styles.restoreButton}
            >
              <Text style={[styles.restoreText, { color: monetizationEnabled ? colors.textSecondary : colors.textMuted }]}>구매 복원</Text>
            </Pressable>
          </View>
        </LensCard>
      </View>

      {monetizationEnabled ? (
        <LensCard mode={mode}>
        <Text style={[styles.sectionTitle, { color: colors.textPrimary }]}>광고 슬롯</Text>
        <Text style={[styles.caption, { color: colors.textSecondary }]}>
          무료 플랜에는 정책 안전 광고만 배치하고, Pro는 광고 제거 상태로 둡니다. 도박성 광고, 베팅 사이트 광고, 구매 유도 광고는 차단 대상입니다.
        </Text>
        </LensCard>
      ) : null}

      <LensCard mode={mode} variant={proActive ? 'verified' : 'caution'}>
        <Text style={[styles.sectionTitle, { color: colors.textPrimary }]}>Pro 전용 잠금</Text>
        <Text style={[styles.caption, { color: colors.textSecondary }]}>
          무료 상태에서는 아래 기능을 미리 보여주되 실행은 막고, 구독 권한이 확인된 계정에서만 열도록 설계합니다.
        </Text>
        <View style={styles.lockedList}>
          {lockedFeatures.map((feature) => (
            <FeatureRow key={feature} mode={mode} label={proActive ? `${feature} 사용 가능` : `${feature} 잠금`} locked={!proActive} />
          ))}
        </View>
      </LensCard>

      <LensCard mode={mode} variant={decision.appSession.entitlement === 'pro' ? 'verified' : 'neutral'}>
        <Text style={[styles.sectionTitle, { color: colors.textPrimary }]}>계정 DB 상태</Text>
        <Text style={[styles.caption, { color: colors.textSecondary }]}>
          현재 기기 ID는 서버의 user_account.devices에 연결되고, 구독 권한은 billing.subscriptions에서 판단합니다.
        </Text>
        <Text style={[styles.mono, { color: colors.textMuted }]}>
          {decision.appSession.entitlement.toUpperCase()} · {decision.dataLayer.ready ? decision.dataLayer.storage : 'demo'}
        </Text>
      </LensCard>

      <StoreSafeNotice mode={mode} />
    </ScrollView>
  );
}

function FeatureRow({ mode, label, locked }: { mode: ThemeMode; label: string; locked: boolean }) {
