+      if (!filePath || !existsSync(filePath)) {
+        await route.fulfill({ status: 404, body: 'Not found' });
+        return;
+      }
+      await route.fulfill({
+        body: readFileSync(filePath),
+        contentType: mimeTypes[extname(filePath)] ?? 'application/octet-stream',
+        status: 200
+      });
+    });
+  }
