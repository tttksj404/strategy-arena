          <Text style={[styles.rankMeta, { color: colors.textSecondary }]}>
            {trifectaPick ? trifectaPick.selection : predictedText} · 순서 확률은 별도 표기
          </Text>
        </View>
        <View style={styles.trifectaValue}>
