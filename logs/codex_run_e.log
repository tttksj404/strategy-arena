+          </Text>
+        </View>
+      </View>
+    </LensCard>
+  );
+}
+
 function PickSelection({ mode, pick, sport }: { mode: ThemeMode; pick: RacePick; sport: Sport }) {
   const colors = palette(mode);
   const numbers = selectionNumbers(pick.selection);

