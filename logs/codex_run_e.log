test('store safety and pro surfaces avoid betting actions', async ({ page }) => {
  const errors = collectErrors(page);
  await page.goto('/');

  await expect(page.getByText('정보 분석 도구')).toBeVisible();
  await page.getByRole('tab', { name: /Pro/ }).click();
  await expect(page.getByText('무료 플랜', { exact: true })).toBeVisible();
  await expect(page.getByText('Pro 플랜', { exact: true })).toBeVisible();
  await expect(page.getByText('월 5,000원', { exact: true })).toBeVisible();
  await expect(page.getByText('현재 적용 상태', { exact: true })).toBeVisible();
  await expect(page.getByText('무료 경험', { exact: true })).toBeVisible();
  await expect(page.getByText('오늘 0/3 사용', { exact: true })).toBeVisible();
  await expect(page.getByText('3회', { exact: true })).toBeVisible();
  await expect(page.getByText('분석 중간 광고 슬롯 표시', { exact: true })).toBeVisible();
  await expect(page.getByText('값은 가리고 잠금 카드 노출', { exact: true })).toBeVisible();
  await expect(page.getByText('Pro 전용 잠금', { exact: true })).toBeVisible();
  await expect(page.getByText('고확신 후보만 모아보기 잠금', { exact: true })).toBeVisible();
  await expect(page.getByText('광고 슬롯', { exact: true })).toBeVisible();
  await expect(page.getByText(/도박성 광고/)).toBeVisible();
  await expect(page.getByRole('button', { name: /구매|베팅|결제/ })).toHaveCount(0);
  expect(errors).toEqual([]);
});

