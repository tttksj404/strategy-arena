          <Text style={[styles.adCreativeCopy, { color: colors.textSecondary }]}>분석 화면은 광고 확인 후 바로 열립니다.</Text>
        </View>
        <Pressable
          accessibilityRole="button"
          accessibilityLabel="광고 확인 후 분석 보기"
          onPress={onConfirm}
          style={({ pressed }) => [
            styles.adConfirm,
            {
              backgroundColor: colors.accentPrimary,
              opacity: pressed ? 0.88 : 1
            }
          ]}
        >
          <Text style={[styles.adConfirmText, { color: colors.textOnBoard }]}>광고 확인 후 분석 보기</Text>
        </Pressable>
        <Pressable
          accessibilityRole="button"
          accessibilityLabel="광고 닫기"
          onPress={onCancel}
