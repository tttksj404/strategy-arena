+
+function hasNoRaceSignal(decision: RaceDecision) {
+  const combined = [
+    decision.headline,
+    decision.marketRisk.title,
+    decision.marketRisk.message,
+    decision.dataLayer.error ?? ''
+  ].join(' ');
+  return /no[_\s-]?race|경주가\s*없|경기가\s*없/.test(combined);
+}
