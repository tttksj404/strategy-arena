	<script>
		//키보드 새로고침 제어
		fnPreventRefresh();

		//상세, 요약 출주표 팝업
		//pdfType: 1=상세, 2=요약
		async function fnRaceCardPdfPopup(pdfType, stndYear, tms, dayOrd) {
			const url = fnGetUrl("/race/card/decision/download/pdf" + pdfType, stndYear, tms, dayOrd);
			fnOpenWinPopup("pdfPopup", url);
		}

		//텍스트 출주표 팝업(확정)
		async function fnRaceCardTxtPopup(stndYear, tms, dayOrd) {
			const url = fnGetUrl("/race/card/decision/popup/txt", stndYear, tms, dayOrd);
			const result = await fnFetch.get(url);
			fnOpenModalPopup("텍스트 출주표 - 확정", result);
		}
	</script>

