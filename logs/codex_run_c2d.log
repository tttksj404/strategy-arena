    for name in ("DATAGOKR_SERVICE_KEY", "datagokr", "DATAGOKR", "DATA_GO_KR_KEY", "SERVICE_KEY"):
        value = os.environ.get(name)
        if value and value.strip():
            return value.strip()
    return None


