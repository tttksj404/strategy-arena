+  if (sport === 'horse') {
+    return {
+      accent: colors.accentGold,
+      accentOn: mode === 'light' ? colors.textOnBoard : colors.surfaceBoard,
+      secondary: colors.accentTurf,
+      headerTint: colors.accentTurf,
+      chipActive: colors.accentGold,
+      pickHighlight: colors.accentGold,
+      tabActive: colors.accentGold
+    };
+  }
+  return {
+    accent: colors.accentSignal,
+    accentOn: mode === 'light' ? colors.textPrimary : colors.surfaceBase,
