        raceNo={raceNo}
        raceDates={raceDates}
        onAnalyze={onAnalyze}
        onDateChange={onDateChange}
        onMeetChange={onMeetChange}
        onRaceChange={onRaceChange}
        onSportChange={onSportChange}
      />

      <StoreSafeNotice mode={mode} compact />
    </ScrollView>
  );
}

