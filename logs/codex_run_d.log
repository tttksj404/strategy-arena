+  accentTurf: { light: '#1E6B4F', dark: '#4FC08D' },
   accentAmber: { light: '#A86500', dark: '#F4B83F' },
   accentRose: { light: '#B4233F', dark: '#FF6F8A' },
   accentViolet: { light: '#5A45C8', dark: '#AA98FF' },
@@ -61,6 +62,7 @@
 } as const;
 
 export type ThemeMode = 'light' | 'dark';
