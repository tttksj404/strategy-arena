# Copy to deploy/oracle/.env.oracle on the Oracle server.
# Do not commit the real .env.oracle file.

# Local/IP smoke mode:
ORACLE_SITE_ADDRESS=:80
# Store/release mode with automatic Caddy TLS:
# ORACLE_SITE_ADDRESS=api.your-racelens-domain.com
ACME_EMAIL=admin@example.com
RACELENS_SUPPORT_EMAIL=support@your-racelens-domain.com

DATAGOKR_SERVICE_KEY=
POSTGRES_PASSWORD=change-me-long-random-password

KCYCLE_ENABLED=1
KCYCLE_TRIFECTA_ENABLED=1
KCYCLE_TRIFECTA_SNAPSHOT_MIN_INTERVAL_SEC=10
KCYCLE_COLLECTOR_INTERVAL_SEC=15
SEARCH_LOOP_INTERVAL_SEC=3600

# Production entitlement: force_pro must stay 0. Preview only via RACELENS_PRO_DEVICE_IDS.
RACELENS_ENV=production
RACELENS_FORCE_PRO=0
RACELENS_ADMIN_TOKEN=change-me-40-char-random-token
RACELENS_LIVE_DECISION_IP_PER_MIN_CAP=60
RACELENS_FREE_DAILY_ANALYSIS_LIMIT=3
RACELENS_REWARDED_ADS_ENABLED=0
# Enable only after the AdMob rewarded unit's SSV callback URL points to:
# https://YOUR_DOMAIN/api/rewarded-ad/ssv
RACELENS_ADMOB_REWARDED_AD_UNIT_ID=

WEB_CONCURRENCY=2
WEB_THREADS=2
WEB_TIMEOUT=120
