# Copy to deploy/oracle/.env.oracle on the Oracle server.
# Do not commit the real .env.oracle file.

ORACLE_SITE_ADDRESS=:80
ACME_EMAIL=admin@example.com

DATAGOKR_SERVICE_KEY=

KCYCLE_ENABLED=1
KCYCLE_TRIFECTA_ENABLED=1
KCYCLE_TRIFECTA_SNAPSHOT_MIN_INTERVAL_SEC=10
KCYCLE_COLLECTOR_INTERVAL_SEC=15
SEARCH_LOOP_INTERVAL_SEC=3600

WEB_CONCURRENCY=2
WEB_THREADS=2
WEB_TIMEOUT=120
