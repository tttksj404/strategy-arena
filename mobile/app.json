{
  "expo": {
    "name": "RaceLens",
    "slug": "racelens",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "racelens",
    "userInterfaceStyle": "automatic",
    "description": "경륜·경마 경주 데이터를 분석하고 모델 신호와 검증 리스크를 투명하게 보여주는 정보 앱입니다.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tttksj.racelens",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tttksj.racelens",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080A0D"
      },
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": ""
    },
    "plugins": [
      "expo-font",
      "expo-status-bar"
    ]
  }
}
