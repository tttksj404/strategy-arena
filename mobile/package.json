{
  "name": "racelens-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export --platform web",
    "qa:mobile": "npm run export:web && playwright test",
    "lint:design": "node scripts/check-design-tokens.mjs && node scripts/check-design-resources.mjs",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "lint:design-resources": "node scripts/check-design-resources.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "expo": "^57.0.1",
    "expo-blur": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
