{
  "name": "racelens-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "npm run export:web",
    "build:android:preview": "node scripts/with-workspace-junction-detached.mjs npx --yes eas-cli@latest build --platform android --profile preview --non-interactive --wait",
    "build:android:production": "npm run qa:store-readiness && node scripts/with-workspace-junction-detached.mjs npx --yes eas-cli@latest build --platform android --profile production --non-interactive --wait",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export --platform web --clear",
    "qa:mobile": "node scripts/qa-mobile.mjs",
    "qa:api-live": "node scripts/qa-api-live.mjs",
    "qa:e2e-live": "node scripts/qa-e2e-live.mjs",
    "qa:live-preview": "node scripts/qa-live-preview.mjs",
    "qa:api-failure": "node scripts/qa-api-failure.mjs",
    "qa:analytics": "node scripts/qa-analytics.mjs",
    "qa:adversarial": "node scripts/qa-adversarial.mjs",
    "qa:release-visual": "node scripts/qa-release-visual.mjs",
    "qa:full-functional": "node scripts/qa-full-functional-audit.mjs",
    "qa:store-readiness": "node scripts/check-store-release-env.mjs",
    "qa:store-pack": "node scripts/check-store-pack.mjs",
    "qa:server": "node scripts/qa-server.mjs",
    "qa:submission": "npm run qa:release && npm run qa:store-readiness && npm run qa:server",
    "qa:release": "npm run qa:preflight && npm run qa:api-failure && npm run qa:adversarial && npm run qa:release-visual",
    "qa:preflight": "npm run lint:design && npm run lint:security && npm run typecheck && npm audit --audit-level=moderate && npx expo-doctor && npm run qa:mobile && npm run qa:api-live && npm run qa:analytics",
    "lint:design": "node scripts/check-design-tokens.mjs && node scripts/check-design-resources.mjs && node scripts/check-design-contrast.mjs",
    "lint:design-tokens": "node scripts/check-design-tokens.mjs",
    "lint:design-resources": "node scripts/check-design-resources.mjs",
    "lint:design-contrast": "node scripts/check-design-contrast.mjs",
    "lint:security": "node scripts/check-security-surface.mjs",
    "preview:build": "node scripts/preview-build.mjs",
    "preview:serve": "node scripts/preview-server.mjs",
    "preview": "node scripts/preview.mjs",
    "preview:live": "bash scripts/live-preview-control.sh start",
    "preview:live:restart": "bash scripts/live-preview-control.sh restart",
    "preview:live:smoke": "bash scripts/live-preview-control.sh smoke",
    "preview:live:status": "bash scripts/live-preview-control.sh status",
    "preview:live:stop": "bash scripts/live-preview-control.sh stop"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-firebase/analytics": "^25.1.0",
    "@react-native-firebase/app": "^25.1.0",
    "@react-native-firebase/crashlytics": "^25.1.0",
    "expo": "~57.0.6",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "~57.0.5",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.6",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
