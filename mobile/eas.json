{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_RACELENS_REWARDED_ADS": "1",
        "EXPO_PUBLIC_RACELENS_ADMOB_TEST_MODE": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_RACELENS_API_BASE_URL": "https://strategy-arena.onrender.com",
        "EXPO_PUBLIC_RACELENS_ANALYTICS_URL": "https://strategy-arena.onrender.com/api/ux-events",
        "RACELENS_PRIVACY_URL": "https://strategy-arena.onrender.com/legal/privacy",
        "RACELENS_TERMS_URL": "https://strategy-arena.onrender.com/legal/terms",
        "RACELENS_ACCOUNT_DELETION_URL": "https://strategy-arena.onrender.com/legal/account-deletion",
        "RACELENS_SUPPORT_URL": "https://strategy-arena.onrender.com/legal/support",
        "RACELENS_SUPPORT_EMAIL": "tttksj@gmail.com",
        "RACELENS_BILLING_MODE": "disabled",
        "EXPO_PUBLIC_RACELENS_FIREBASE_AUTH_ENABLED": "0",
        "EXPO_PUBLIC_RACELENS_OFFLINE_EXAMPLE": "0"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "applicationId": "com.tttksj.racelens",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
