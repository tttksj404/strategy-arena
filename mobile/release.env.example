EXPO_PUBLIC_RACELENS_API_BASE_URL=https://api.your-racelens-domain.invalid
EXPO_PUBLIC_RACELENS_ANALYTICS_URL=https://api.your-racelens-domain.invalid/api/ux-events
RACELENS_PRIVACY_URL=https://api.your-racelens-domain.invalid/legal/privacy
RACELENS_TERMS_URL=https://api.your-racelens-domain.invalid/legal/terms
RACELENS_ACCOUNT_DELETION_URL=https://api.your-racelens-domain.invalid/legal/account-deletion
RACELENS_SUPPORT_EMAIL=support@your-racelens-domain.invalid
RACELENS_SUPPORT_URL=https://api.your-racelens-domain.invalid/legal/support
RACELENS_BILLING_MODE=disabled
# Firebase Analytics/Crashlytics are enabled for production observability.
# If this is 1, privacy policy and Play Data safety must disclose Firebase/Google processing.
EXPO_PUBLIC_RACELENS_FIREBASE_ENABLED=1
EXPO_PUBLIC_RACELENS_FIREBASE_AUTH_ENABLED=0
RACELENS_FIREBASE_PROJECT_ID=racelens-tttksj
GOOGLE_SERVICES_JSON=google-services.json
RACELENS_FIREBASE_ANDROID_SERVICES_FILE=google-services.json
# Production builds fail closed until real AdMob IDs replace these blanks.
EXPO_PUBLIC_RACELENS_REWARDED_ADS=1
EXPO_PUBLIC_RACELENS_ADMOB_TEST_MODE=0
EXPO_PUBLIC_RACELENS_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_RACELENS_ADMOB_REWARDED_AD_UNIT_ID=
# The Oracle server must use the exact same rewarded unit for signed SSV callbacks.
RACELENS_ADMOB_REWARDED_AD_UNIT_ID=
